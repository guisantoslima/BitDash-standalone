
# Porta do servidor local (bind sempre em 127.0.0.1)
BITDASH_PORT=8080

# Modo debug (true/false) - ativa logs verbosos
BITDASH_DEBUG=false

# Caminho do executável Python (deixe vazio para usar "python3" do PATH)
BITDASH_PYTHON_PATH=

# Locale padrão da aplicação
BITDASH_LOCALE=pt-BR

# Caminho do workspace (opcional - se vazio, usa pasta padrão do OS)
BITDASH_WORKSPACE_PATH=

